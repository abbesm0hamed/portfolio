{
  "name": "portfolio",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "@cloudflare/workers-types": "^4.20260702.1",
      "alchemy": "^0.93.12"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vp run --filter web dev",
    "build": "vp run -r build",
    "check-types": "vp run -r check-types",
    "check": "ultracite check",
    "lint": "vp lint",
    "format": "vp fmt",
    "staged": "vp staged",
    "dev:web": "vp run --filter web dev",
    "deploy": "vp run --filter @portfolio/infra deploy",
    "destroy": "vp run --filter @portfolio/infra destroy",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@portfolio/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@portfolio/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "rolldown": "1.1.4",
    "typescript": "catalog:",
    "ultracite": "7.9.3",
    "vite-plus": "0.2.2"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2"
  },
  "packageManager": "bun@1.3.14"
}
