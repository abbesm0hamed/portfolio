---
import { getCollection, render } from "astro:content";
import { Icons } from "@workspace/ui/icons";
import Layout from "@/layouts/main.astro";

export async function getStaticPaths() {
  const writings = await getCollection("writings");
  return writings.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

if (!entry) {throw new Error("Writing not found");}

const { Content } = await render(entry);
const { title, date } = entry.data;

const base = import.meta.env.PUBLIC_SERVER_URL as string;
const mdUrl = `${base}/content/writings/${entry.id}.md`;
const promptText = `Please read and summarize this article, then be ready to answer questions about it: ${mdUrl}`;
const chatgptUrl = `https://chatgpt.com/?q=${encodeURIComponent(promptText)}`;
const claudeUrl = `https://claude.ai/new?q=${encodeURIComponent(promptText)}`;
---

<Layout>
  <div
    class="h-full overflow-y-auto [scrollbar-width:none]"
    id="main-scroll"
  >
    <div class="max-w-3xl mx-auto py-8 space-y-10 border-x">
      <div class="flex justify-between border-y">
        <a
          href="/"
          class="w-control h-control flex items-center justify-center text-muted-foreground hover:text-foreground hover:bg-muted transition-colors border-r border-r-border"
        >
          <Icons.ChevronLeft className="size-4" />
        </a>

        <div class="flex">
          <a
            href={chatgptUrl}
            target="_blank"
            rel="noopener"
            title="Summarize with ChatGPT"
            class="w-control h-control flex items-center justify-center text-muted-foreground hover:text-foreground transition-colors border-l border-l-border"
          >
            <Icons.OpenAI className="size-4" />
          </a>
          <a
            href={claudeUrl}
            target="_blank"
            rel="noopener"
            title="Summarize with Claude"
            class="w-control h-control flex items-center justify-center text-muted-foreground hover:text-foreground transition-colors border-l border-l-border"
          >
            <Icons.Claude className="size-4" />
          </a>
        </div>
      </div>

      <div class="border-y">
        <h1
          class="text-[clamp(1.5rem,4vw,3rem)] font-bold tracking-[0.08em] leading-none mb-4"
        >
          {title}
        </h1>

        <span class="text-[0.625rem] tracking-[0.2em] uppercase text-muted-foreground">
          {date} — Post
        </span>
      </div>

      <div class="prose max-w-prose">
        <Content />
      </div>
    </div>
  </div>
</Layout>

<style>
  .prose :global(h2) {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .prose :global(h3) {
    font-size: clamp(0.875rem, 1.5vw, 1.125rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
    line-height: 1.75;
    color: hsl(var(--muted-foreground));
  }

  .prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose :global(li) {
    margin-bottom: 0.25rem;
    line-height: 1.75;
    color: hsl(var(--muted-foreground));
  }

  .prose :global(strong) {
    font-weight: 600;
  }

  .prose :global(code) {
    font-size: 0.875em;
    background: hsl(var(--muted));
    padding: 0.125rem 0.375rem;
  }

  .prose :global(pre) {
    background: hsl(var(--muted));
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
    border: 1px solid hsl(var(--border));
  }

  .prose :global(a) {
    color: hsl(var(--foreground));
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(blockquote) {
    border-left: 3px solid hsl(var(--border));
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: hsl(var(--muted-foreground));
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid hsl(var(--border));
    margin: 2rem 0;
  }
</style>
