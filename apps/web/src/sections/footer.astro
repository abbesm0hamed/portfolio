---
import { Icons } from "@workspace/ui/icons"
---

<footer class="flex flex-col">
  <div class="h-control border-t">
    <div class="h-full container">
      <div class="h-full border-x flex justify-between">
        <button
          data-scroll="down"
          aria-label="Scroll down"
          class="h-full w-control border-r border-r-border text-muted-foreground hover:text-foreground hover:bg-muted transition-colors inline-flex items-center justify-center [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg]:size-4"
        >
          <Icons.ArrowDown />
        </button>
        <div class="flex-1 bg-grain" />
        <button
          data-scroll="up"
          aria-label="Scroll up"
          class="h-full w-control border-l border-l-border text-muted-foreground hover:text-foreground hover:bg-muted transition-colors inline-flex items-center justify-center [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg]:size-4"
        >
          <Icons.ArrowUp />
        </button>
      </div>
    </div>
  </div>
  <div class="h-control border-t">
    <div class="h-full container">
      <div class="h-full border-x"></div>
    </div>
  </div>
</footer>

<script>
  const SCROLL_RATIO = 0.85

  const scrollMain = (direction: "up" | "down") => {
    const root = document.querySelector("#main-scroll")
    if (!root) {
      return
    }

    const amount = root.clientHeight * SCROLL_RATIO
    root.scrollBy({
      behavior: "smooth",
      top: direction === "down" ? amount : -amount,
    })
  }

  document.querySelector("footer")?.addEventListener("click", (event) => {
    const target = (event.target as HTMLElement | null)?.closest("[data-scroll]")
    if (!(target instanceof HTMLElement)) {
      return
    }

    const direction = target.dataset.scroll
    if (direction === "up" || direction === "down") {
      scrollMain(direction)
    }
  })
</script>
