---
import { Icons } from "@workspace/ui/icons";
import type { SetupItem } from "./data";

interface Props {
  items: SetupItem[];
}

const { items } = Astro.props;
---

<div class="h-full flex-1 flex flex-col layout:border-l max-layout:border-t relative">
  <div class="flex justify-between items-center h-control border-b">
    <span class="text-[0.7rem] leading-none tracking-[0.2em] uppercase text-muted-foreground pl-6">
      Setup
    </span>
    <a
      href="https://github.com/abbesm0hamed/dofs"
      rel="noopener noreferrer"
      target="_blank"
      class="flex h-control w-control border-l border-border items-center justify-center text-muted-foreground hover:text-foreground transition-colors [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg]:size-4"
    >
      <Icons.GitRepository />
    </a>
  </div>
  <div
    data-terminal-scroll
    class="flex-1 min-h-0 overflow-y-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
  >
    <div class="p-6 font-mono text-xs space-y-6">
      {items.map((item) => (
        <div class="space-y-1">
          <div class="flex items-baseline gap-2">
            <span class="text-muted-foreground/50 select-none pt-0.5">
              $
            </span>
            <span class="text-foreground/80">{item.cmd}</span>
          </div>
          <div class="ml-5 space-y-1">
            <span class="text-muted-foreground/50 select-none">
              # {item.category}
            </span>
            <div class="text-foreground font-semibold">
              {item.title}
            </div>
            <p class="text-muted-foreground leading-relaxed">
              {item.desc}
            </p>
          </div>
        </div>
      ))}
      <div class="flex items-center gap-2 text-muted-foreground/50">
        <span class="flex items-center justify-center pt-[0.2rem]">
          $
        </span>
        <span class="w-[0.35rem] h-[1em] bg-current animate-blink" />
      </div>
    </div>
  </div>
  <div
    data-scroll-indicator
    class="absolute bottom-4 left-1/2 -translate-x-1/2 pointer-events-none flex flex-col items-center gap-1.5 text-muted-foreground opacity-0 translate-y-1 transition-all duration-300 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg]:size-3.5"
  >
    <span class="text-[0.625rem] tracking-[0.25em] uppercase font-mono bg-background/90 px-2 py-1 rounded border border-border backdrop-blur-xs shadow-xs">
      More
    </span>
    <Icons.ArrowDown class="animate-bounce text-muted-foreground/80" />
  </div>
</div>

<script>
  function initTerminalScroll() {
    const scrollEl = document.querySelector("[data-terminal-scroll]");
    const indicator = document.querySelector("[data-scroll-indicator]");
    if (!(scrollEl instanceof HTMLElement) || !(indicator instanceof HTMLElement)) {
      return;
    }

    const check = () => {
      const { scrollTop, scrollHeight, clientHeight } = scrollEl;
      const isScrollable = scrollHeight > clientHeight;
      const isAtBottom = scrollTop + clientHeight >= scrollHeight - 10;
      const show = isScrollable && !isAtBottom;

      indicator.classList.toggle("opacity-100", show);
      indicator.classList.toggle("translate-y-0", show);
      indicator.classList.toggle("opacity-0", !show);
      indicator.classList.toggle("translate-y-1", !show);
    };

    check();

    const observer = new ResizeObserver(check);
    observer.observe(scrollEl);
    scrollEl.addEventListener("scroll", check);
  }

  initTerminalScroll();
</script>
