---
import { SocialBar } from "@/components/social-bar"
import { ResumeButton } from "@/components/resume-button"
---

<div class="layout:border-r border-b flex flex-col justify-between overflow-hidden min-h-0">
  <div class="flex-1 flex flex-col justify-center p-6">
    <span class="text-[clamp(1.5rem,5vw,1.75rem)] font-bold tracking-[0.15em] leading-none">Mohamed Abbes</span>
    <span class="text-[0.9125rem] tracking-[0.2em] uppercase text-muted-foreground mt-2 font-semibold">Code Composer!</span>
    <p class="text-[1.1rem] text-muted-foreground leading-relaxed mt-2">
      Software engineer with a background in embedded systems. I build across the stack and care about the details — from how something feels to how it runs.
    </p>
  </div>
  <div class="h-control border-t border-t-border shrink-0 flex">
    <SocialBar client:load />
    <div class="flex-1 bg-grain h-full" />
    <ResumeButton client:load />
  </div>
</div>

<div class="w-full p-2 border-b bg-surface overflow-hidden min-h-0 max-layout:min-h-[18rem] max-layout:max-h-[25rem] max-layout:aspect-[16/10] layout:h-full layout:min-h-0 layout:aspect-auto">
  <img src="/images/me/young_me.jpeg" alt="Young Mohamed at a computer" class="size-full object-cover" />
</div>
