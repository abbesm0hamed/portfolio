---
const projects = [
  {
    desc: "A short description of what this project does and why it matters. This is the expanded view with full details about the project, the problem it solved, and the technology behind it.",
    id: "project-01",
    label: "01 — Project",
    name: "Project One",
    role: "Full-Stack",
    stack: "TypeScript, React",
    year: "2025",
  },
  {
    desc: "Another project, different scope, same attention to detail. Expanded view with full case study content.",
    id: "project-02",
    label: "02 — Project",
    name: "Project Two",
    role: "Frontend",
    stack: "Astro, Tailwind",
    year: "2025",
  },
  {
    desc: "The one that taught me the most. Full-stack, end to end. Expanded view with full case study content.",
    id: "project-03",
    label: "03 — Project",
    name: "Project Three",
    role: "Backend",
    stack: "Go, PostgreSQL",
    year: "2024",
  },
];
---

{projects.map((p) => (
  <section id={p.id} class="overlay fixed inset-0 bg-background z-50 p-8 overflow-y-auto border border-border">
    <div class="flex justify-between items-center pb-8 border-b border-border mb-8">
      <span class="text-[0.625rem] tracking-[0.2em] uppercase text-muted-foreground">{p.label}</span>
      <a href="#" class="text-[0.6875rem] tracking-[0.15em] uppercase text-muted-foreground py-2 px-4 border border-border hover:bg-muted">Close ✕</a>
    </div>
    <div class="grid grid-cols-[1fr_2fr] gap-12 flex-1 max-[900px]:grid-cols-1">
      <div class="flex flex-col gap-6">
        <div class="flex flex-col gap-1.5">
          <span class="text-[0.625rem] tracking-[0.2em] uppercase text-muted-foreground">Year</span>
          <span class="text-[0.9375rem]">{p.year}</span>
        </div>
        <div class="flex flex-col gap-1.5">
          <span class="text-[0.625rem] tracking-[0.2em] uppercase text-muted-foreground">Stack</span>
          <span class="text-[0.9375rem]">{p.stack}</span>
        </div>
        <div class="flex flex-col gap-1.5">
          <span class="text-[0.625rem] tracking-[0.2em] uppercase text-muted-foreground">Role</span>
          <span class="text-[0.9375rem]">{p.role}</span>
        </div>
      </div>
      <div>
        <h2 class="text-[clamp(2rem,5vw,4rem)] font-bold tracking-[0.08em] leading-none mb-8">{p.name}</h2>
        <p class="text-[1.0625rem] leading-[1.8] text-muted-foreground">{p.desc}</p>
      </div>
    </div>
  </section>
))}
